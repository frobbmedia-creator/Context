  "author": "Frobb Media",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chokidar": "^4.0.1",
    "clipboardy": "^4.0.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.2"
  },
  "optionalDependencies": {
    "tiktoken": "^1.0.17"
  },
  "files": [
    "bin/",
    "cli/",
    "src/",
    "README.md",
    "LICENSE.md"
  ],
  "repository": {
    "type": "git",
