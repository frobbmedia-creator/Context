  "bin": {
    "context": "bin/context.js"
  },
  "scripts": {
    "start": "node bin/context.js",
    "cli": "node bin/context.js",
    "test": "node --test tests/*.test.js",
    "pack": "npm pack"
  },
  "keywords": [
    "llm",
    "context",
    "prompt",
    "git",
    "local-first",
    "claude",
    "gpt",
    "ollama",
    "tokenizer",
